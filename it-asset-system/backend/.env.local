# Database Configuration (PostgreSQL) - Local Development
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=it_asset_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# QR Code Configuration
QR_CODE_SIZE=300
QR_CODE_PATH=./public/qrcodes
